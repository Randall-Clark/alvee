modules = ["nodejs-24"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["github:1.0.0", "stripe:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 19947
externalPort = 80

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
JWT_SECRET = "8bf2e0291b27ff1df9e9ba5e6892360563f6c338ef50c4035934c3d6d77a57c7093e005a0fe553792473f110b216ebe55cd0eacc1598df3d28474190a42bfce6"
